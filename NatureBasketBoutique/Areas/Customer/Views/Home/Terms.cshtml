@{
    ViewData["Title"] = "Terms & Conditions";
}

<div class="container mx-auto px-4 py-12 max-w-4xl">
    <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-gray-100">
        <h1 class="text-4xl font-black text-gray-900 mb-2">Terms & Conditions</h1>
        <p class="text-gray-500 mb-8 pb-8 border-b border-gray-200">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

        <div class="prose prose-green max-w-none text-gray-700 space-y-6">
            <h3 class="text-xl font-bold text-gray-900">1. Introduction</h3>
            <p>Welcome to Nature Basket Boutique. By accessing our website, you agree to these terms and conditions.</p>

            <h3 class="text-xl font-bold text-gray-900">2. Products and Pricing</h3>
            <p>All organic products are subject to availability. Prices for our products are subject to change without notice.</p>

        </div>
    </div>
</div>